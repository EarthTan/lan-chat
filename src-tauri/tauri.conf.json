{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LAN Chat",
  "version": "1.0.0",
  "identifier": "io.github.lanchat",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "LAN Chat",
        "width": 960,
        "height": 700,
        "minWidth": 600,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
